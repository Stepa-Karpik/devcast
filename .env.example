# --- Core ---
# Local dev defaults (host ports from docker-compose: pg 5433, redis 6380)
DATABASE_URL=postgresql+asyncpg://devcast:devcast@localhost:5433/devcast
REDIS_URL=redis://localhost:6380/0

# Generate with: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-please

# Generate with: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=change-me-fernet-key

# Public base URL of THIS app (used for OAuth callbacks). In dev use your tunnel URL.
PUBLIC_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173

# --- GitHub App ---
# Create at https://github.com/settings/apps  (Webhook URL = ${PUBLIC_BASE_URL}/api/webhooks/github)
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=
# Paste the PEM contents on a single line with \n, or set GITHUB_APP_PRIVATE_KEY_PATH instead.
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=

# --- Notion (OAuth, multi-user) ---
# Public OAuth integration (https://www.notion.so/profile/integrations -> New connection -> OAuth).
# Redirect URI = ${PUBLIC_BASE_URL}/api/integrations/notion/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
# Optional: internal integration token, used only as a local-dev fallback.
NOTION_DEFAULT_TOKEN=

# --- Google Calendar (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
